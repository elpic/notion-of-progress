{
  "name": "notion-of-progress",
  "version": "1.0.0",
  "description": "AI-powered daily standup agent using Notion MCP and Claude",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "standup": "tsx scripts/run-mcp.ts",
    "setup": "tsx scripts/setup.ts",
    "digest": "tsx scripts/run-digest.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.39.0",
    "@notionhq/client": "^2.3.0",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
