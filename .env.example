# ─── Required ────────────────────────────────────────────────────────────────

# Notion integration token (https://www.notion.com/my-integrations)
NOTION_API_KEY=secret_...

# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Auto-filled by `npm run setup` ──────────────────────────────────────────

NOTION_TASK_DB_ID=
NOTION_STANDUP_LOG_DB_ID=
NOTION_SYSTEM_STATUS_DB_ID=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Scheduler: weekdays at 08:00 by default
CRON_SCHEDULE=0 8 * * 1-5
# Weekly digest: Fridays at 17:00 by default
DIGEST_CRON_SCHEDULE=0 17 * * 5
TZ=America/New_York

# Notion property names — change only if your Task DB uses different names
TASK_STATUS_PROPERTY=Status
TASK_DONE_VALUE=Done
TASK_TITLE_PROPERTY=Name

# ─── Integrations (optional) ─────────────────────────────────────────────────

# Discord webhook URL — post standup summary to a channel after generation
# See docs/integrations/discord.md for setup instructions
DISCORD_WEBHOOK_URL=
