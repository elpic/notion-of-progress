# ================================================================
# Notion of Progress Configuration
# ================================================================

# ─── Required API Keys ───────────────────────────────────────────
# These are REQUIRED for the system to function

# Notion integration token 
# 1. Go to https://www.notion.com/my-integrations
# 2. Create a new integration
# 3. Copy the "Internal Integration Token"
NOTION_API_KEY=secret_...

# Anthropic Claude API key
# 1. Go to https://console.anthropic.com/settings/keys  
# 2. Create a new API key
# 3. Copy the key (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Database IDs (Auto-generated by setup) ──────────────────────
# These are automatically filled by running `mise run setup`
# DO NOT manually edit these values

NOTION_TASK_DB_ID=
NOTION_STANDUP_LOG_DB_ID=
NOTION_SYSTEM_STATUS_DB_ID=

# ─── Local Scheduler Settings ────────────────────────────────────
# Only used when running `mise run start` locally
# GitHub Actions workflows have their own schedules

# Daily standup schedule (cron format) - default: weekdays at 8 AM
CRON_SCHEDULE=0 8 * * 1-5

# Weekly digest schedule (cron format) - default: Fridays at 5 PM  
DIGEST_CRON_SCHEDULE=0 17 * * 5

# Timezone for local runs (GitHub Actions uses UTC)
TZ=America/New_York

# ─── Notion Database Customization ───────────────────────────────
# Change these ONLY if your Task database uses different property names

# Name of the status property in your Task database
TASK_STATUS_PROPERTY=Status

# Status value that means "task is completed"
TASK_DONE_VALUE=Done

# Name of the title property in your Task database  
TASK_TITLE_PROPERTY=Name

# ─── Optional Integrations ───────────────────────────────────────

# Discord webhook URL for team notifications
# 1. In Discord: Server Settings → Integrations → Webhooks → New Webhook
# 2. Copy the webhook URL
# 3. Standups will be posted to this channel automatically
DISCORD_WEBHOOK_URL=

# ================================================================
# Setup Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in NOTION_API_KEY and ANTHROPIC_API_KEY above
# 3. Run setup: mise run setup
# 4. The setup script will fill in the database IDs automatically
# ================================================================