# Notion
NOTION_API_KEY=secret_...
NOTION_TASK_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_STANDUP_LOG_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Scheduler (weekdays at 08:00 by default)
CRON_SCHEDULE=0 8 * * 1-5
TZ=America/New_York

# Notion property names (adjust to match your task DB)
TASK_STATUS_PROPERTY=Status
TASK_DONE_VALUE=Done
TASK_TITLE_PROPERTY=Name
