/**
 * scripts/setup-github-secrets.ts
 *
 * Helps set up GitHub repository secrets for automated deployment.
 * 
 * This script reads your local .env file and provides the exact commands
 * needed to set up GitHub secrets, either via GitHub CLI or web interface.
 *
 * Usage:
 *   npm run setup-secrets
 *   
 * Prerequisites:
 *   1. GitHub CLI installed (gh) - for automatic setup
 *   2. GitHub repository initialized and pushed
 *   3. Local .env file configured with working values
 */

import 'dotenv/config';
import { existsSync, readFileSync } from 'fs';
import { join } from 'path';

interface SecretConfig {
  name: string;
  value: string | undefined;
  required: boolean;
  description: string;
}

function getRequiredSecrets(): SecretConfig[] {
  return [
    {
      name: 'NOTION_API_KEY',
      value: process.env.NOTION_API_KEY,
      required: true,
      description: 'Notion integration token from https://www.notion.com/my-integrations'
    },
    {
      name: 'ANTHROPIC_API_KEY', 
      value: process.env.ANTHROPIC_API_KEY,
      required: true,
      description: 'Anthropic API key from https://console.anthropic.com/settings/keys'
    },
    {
      name: 'NOTION_TASK_DB_ID',
      value: process.env.NOTION_TASK_DB_ID,
      required: true,
      description: 'Task database ID (auto-generated by setup script)'
    },
    {
      name: 'NOTION_STANDUP_LOG_DB_ID',
      value: process.env.NOTION_STANDUP_LOG_DB_ID,
      required: true,
      description: 'Standup log database ID (auto-generated by setup script)'
    },
    {
      name: 'NOTION_SYSTEM_STATUS_DB_ID',
      value: process.env.NOTION_SYSTEM_STATUS_DB_ID,
      required: true,
      description: 'System status database ID (auto-generated by setup script)'
    },
    {
      name: 'DISCORD_WEBHOOK_URL',
      value: process.env.DISCORD_WEBHOOK_URL,
      required: false,
      description: 'Discord webhook URL for notifications (optional)'
    }
  ];
}

async function checkGitHubCLI(): Promise<boolean> {
  try {
    const { execSync } = await import('child_process');
    execSync('gh --version', { stdio: 'ignore' });
    return true;
  } catch {
    return false;
  }
}

async function checkGitHubRepo(): Promise<{ owner: string; repo: string } | null> {
  try {
    const { execSync } = await import('child_process');
    const remoteUrl = execSync('git remote get-url origin', { encoding: 'utf8' }).trim();
    
    // Parse GitHub URL (both HTTPS and SSH formats)
    const httpsMatch = remoteUrl.match(/https:\/\/github\.com\/([^\/]+)\/([^\/]+?)(?:\.git)?$/);
    const sshMatch = remoteUrl.match(/git@github\.com:([^\/]+)\/([^\/]+?)(?:\.git)?$/);
    
    if (httpsMatch) {
      return { owner: httpsMatch[1], repo: httpsMatch[2] };
    } else if (sshMatch) {
      return { owner: sshMatch[1], repo: sshMatch[2] };
    }
    
    return null;
  } catch {
    return null;
  }
}

async function setSecretsViaGitHubCLI(secrets: SecretConfig[]): Promise<void> {
  const { execSync } = await import('child_process');
  
  console.log('🚀 Setting up GitHub secrets via GitHub CLI...\n');
  
  for (const secret of secrets) {
    if (!secret.value) {
      if (secret.required) {
        console.log(`❌ Required secret ${secret.name} is missing from .env`);
      } else {
        console.log(`⏭️  Skipping optional secret ${secret.name} (not set in .env)`);
      }
      continue;
    }

    try {
      execSync(`gh secret set ${secret.name} --body "${secret.value}"`, { 
        stdio: 'pipe' 
      });
      console.log(`✅ ${secret.name} set successfully`);
    } catch (error) {
      console.log(`❌ Failed to set ${secret.name}: ${error}`);
    }
  }
  
  console.log('\n🎉 GitHub secrets setup complete!');
  console.log('\n📋 Next steps:');
  console.log('   1. Verify secrets in GitHub repo Settings → Secrets and variables → Actions');
  console.log('   2. Test workflows by triggering them manually');
  console.log('   3. Check Actions tab to see workflow runs');
}

function printManualInstructions(secrets: SecretConfig[], repoInfo: { owner: string; repo: string } | null): void {
  console.log('📖 Manual GitHub Secrets Setup Instructions\n');
  
  if (repoInfo) {
    console.log(`🔗 Repository: https://github.com/${repoInfo.owner}/${repoInfo.repo}`);
    console.log(`🔧 Secrets URL: https://github.com/${repoInfo.owner}/${repoInfo.repo}/settings/secrets/actions\n`);
  } else {
    console.log('🔧 Go to your GitHub repository → Settings → Secrets and variables → Actions\n');
  }
  
  console.log('📋 Add these repository secrets:\n');
  
  for (const secret of secrets) {
    const status = secret.value ? '✅' : (secret.required ? '❌' : '⏭️');
    const value = secret.value || (secret.required ? 'MISSING - CHECK .env' : 'Not set (optional)');
    
    console.log(`${status} ${secret.name}`);
    console.log(`   Description: ${secret.description}`);
    console.log(`   Value: ${secret.value ? '***[HIDDEN]***' : value}`);
    console.log('');
  }
  
  if (secrets.some(s => s.required && !s.value)) {
    console.log('⚠️  Missing required secrets! Run "npm run setup" first to generate database IDs.');
  }
}

function printGitHubCLICommands(secrets: SecretConfig[]): void {
  console.log('\n💻 GitHub CLI Commands (run these manually):\n');
  
  for (const secret of secrets) {
    if (secret.value) {
      console.log(`gh secret set ${secret.name} --body "${secret.value}"`);
    } else if (secret.required) {
      console.log(`# ${secret.name} - MISSING FROM .env`);
    } else {
      console.log(`# gh secret set ${secret.name} --body "your_value_here"  # Optional`);
    }
  }
  
  console.log('\n💡 Tip: Install GitHub CLI with "brew install gh" or "npm install -g @github/cli"');
}

async function main(): Promise<void> {
  console.log('🔐 GitHub Secrets Setup for Notion of Progress\n');

  // Check if .env exists
  const envPath = join(process.cwd(), '.env');
  if (!existsSync(envPath)) {
    console.log('❌ No .env file found. Run "npm run setup" first to configure your environment.\n');
    process.exit(1);
  }

  // Get repository information
  const repoInfo = await checkGitHubRepo();
  if (!repoInfo) {
    console.log('⚠️  Could not detect GitHub repository. Make sure you have a GitHub remote configured.\n');
  }

  // Get secrets configuration
  const secrets = getRequiredSecrets();
  const missingRequired = secrets.filter(s => s.required && !s.value);

  if (missingRequired.length > 0) {
    console.log('❌ Missing required environment variables:\n');
    missingRequired.forEach(secret => {
      console.log(`   ${secret.name} - ${secret.description}`);
    });
    console.log('\n💡 Run "npm run setup" to configure your Notion databases and API keys.\n');
  }

  // Check GitHub CLI availability
  const hasGitHubCLI = await checkGitHubCLI();
  
  if (hasGitHubCLI && missingRequired.length === 0) {
    console.log('✅ GitHub CLI detected. Would you like to set up secrets automatically? (y/N)');
    
    // For automation, we'll just set them up directly
    // In real usage, you'd prompt for user input here
    if (process.argv.includes('--auto') || process.env.CI) {
      await setSecretsViaGitHubCLI(secrets);
      return;
    }
  }

  // Print manual instructions
  printManualInstructions(secrets, repoInfo);
  
  if (hasGitHubCLI) {
    printGitHubCLICommands(secrets);
  }
  
  console.log('\n🚀 After setting up secrets, your GitHub Actions will run automatically:');
  console.log('   📅 Daily standups: Weekdays at 8 AM EST');
  console.log('   📊 Weekly digest: Fridays at 5 PM EST');
  console.log('\n🧪 Test your setup:');
  console.log('   1. Go to Actions tab in your GitHub repo');
  console.log('   2. Select "Daily Standup Automation"');
  console.log('   3. Click "Run workflow" to test manually');
}

main().catch(error => {
  console.error('❌ Setup failed:', error.message);
  process.exit(1);
});